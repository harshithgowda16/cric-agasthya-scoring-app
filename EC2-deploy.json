{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "CloudLabs template with default-like VPC and outputs",

  "Parameters": {
    "CloudLabsDeploymentID": {
      "Description": "DeploymentID Value",
      "Type": "String"
    },
    "AccountId": {
      "Type": "String"
    },
    "userName": {
      "Type": "String"
    },
    "password": {
      "Type": "String"
    }
  },

  "Conditions": {
    "Never": {
      "Fn::Equals": ["a", "b"]
    }
  },

  "Resources": {

    "NullResource": {
      "Type": "Custom::Null",
      "Condition": "Never"
    },

    "MyVPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true,
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "odl-vpc-${CloudLabsDeploymentID}" } }
        ]
      }
    },

    "InternetGateway": {
      "Type": "AWS::EC2::InternetGateway"
    },

    "AttachGateway": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": { "Ref": "MyVPC" },
        "InternetGatewayId": { "Ref": "InternetGateway" }
      }
    },

    "PublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": { "Ref": "MyVPC" },
        "CidrBlock": "10.0.1.0/24",
        "MapPublicIpOnLaunch": true,
        "AvailabilityZone": { "Fn::Select": [0, { "Fn::GetAZs": "" }] },
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "odl-subnet-${CloudLabsDeploymentID}" } }
        ]
      }
    },

    "RouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": { "Ref": "MyVPC" }
      }
    },

    "DefaultRoute": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "AttachGateway",
      "Properties": {
        "RouteTableId": { "Ref": "RouteTable" },
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": { "Ref": "InternetGateway" }
      }
    },

    "SubnetRouteTableAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": { "Ref": "PublicSubnet" },
        "RouteTableId": { "Ref": "RouteTable" }
      }
    },

    "InstanceSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Allow SSH and HTTP",
        "VpcId": { "Ref": "MyVPC" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      }
    }

  },

  "Outputs": {

    "CloudLabsDeploymentID": {
      "Description": "DeploymentID Value",
      "Value": { "Ref": "CloudLabsDeploymentID" }
    },

    "SignInUrl": {
      "Description": "Sign in URL",
      "Value": {
        "Fn::Join": ["", ["https://", { "Ref": "AccountId" }, ".signin.aws.amazon.com/console/"]]
      }
    },

    "UserName": {
      "Description": "username",
      "Value": { "Ref": "userName" }
    },

    "Password": {
      "Description": "password",
      "Value": { "Ref": "password" }
    },

    "EC2InstanceName": {
      "Description": "EC2 Name",
      "Value": { "Fn::Join": ["", ["odl-user-", { "Ref": "CloudLabsDeploymentID" }]] }
    },

    "S3BucketName": {
      "Description": "S3 Bucket Name",
      "Value": { "Fn::Join": ["", ["odl-user-", { "Ref": "CloudLabsDeploymentID" }]] }
    },

    "KeyName": {
      "Description": "Key Name",
      "Value": { "Fn::Join": ["", ["odl-user-", { "Ref": "CloudLabsDeploymentID" }]] }
    },

    "VpcId": {
      "Description": "VPC ID",
      "Value": { "Ref": "MyVPC" }
    },

    "SubnetId": {
      "Description": "Subnet ID",
      "Value": { "Ref": "PublicSubnet" }
    },

    "SecurityGroupId": {
      "Description": "Security Group ID",
      "Value": { "Ref": "InstanceSecurityGroup" }
    }

  }
}
