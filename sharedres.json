{
  "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "parameters": {

    "adminUsername": {
      "type": "string",
      "defaultValue": "prtguser",
      "metadata": { "description": "Admin username applied to all VMs and the SQL logical server." }
    },
    "adminUserPassword": {
      "type": "securestring",
      "defaultValue": "Prtgpassword123!",
      "metadata": { "description": "Admin password applied to all VMs and the SQL logical server." }
    },

    "AzureUserName": {
      "type": "string",
      "defaultValue": "GET-AZUSER-UPN",
      "metadata": { "description": "CloudLabs Azure user UPN — injected by the platform at deploy time." }
    },
    "AzurePassword": {
      "type": "securestring",
      "defaultValue": "GET-AZUSER-PASSWORD",
      "metadata": { "description": "CloudLabs Azure user password — injected by the platform at deploy time." }
    },
    "ODLID": {
      "type": "string",
      "defaultValue": "GET-ODL-ID",
      "metadata": { "description": "CloudLabs ODL identifier — injected by the platform." }
    },
    "DeploymentID": {
      "type": "string",
      "defaultValue": "shared",
      "metadata": { "description": "CloudLabs deployment ID — used to unique-suffix resource names." }
    },
    "InstallCloudLabsShadow": {
      "type": "string",
      "defaultValue": "yes",
      "allowedValues": [ "yes", "no" ],
      "metadata": { "description": "Install the CloudLabs shadow agent on the Windows VM." }
    },
    "trainerUserName": {
      "type": "string",
      "defaultValue": "trainer",
      "metadata": { "description": "Trainer account username for CloudLabs embedded shadow." }
    },
    "trainerUserPassword": {
      "type": "string",
      "defaultValue": "Password.!!1",
      "metadata": { "description": "Trainer account password for CloudLabs embedded shadow." }
    },
    "resetUserPassword": {
      "type": "string",
      "defaultValue": "Prtgpassword123!",
      "metadata": { "description": "The VM password surfaced in CloudLabs lab outputs." }
    },

    "spnClientId": {
      "type": "string",
      "defaultValue": "PRTG-Training-SP",
      "metadata": { "description": "App Registration Client ID (Application ID) for the PRTG-Training-SP service principal." }
    },
    "spnClientSecret": {
      "type": "securestring",
      "defaultValue": "knT8Q~oHl63Muwr7yc27Ijd.Zhc2KtfmItW-yc77",
      "metadata": { "description": "Client secret value for the PRTG-Training-SP service principal." }
    },
    "spnSecretId": {
      "type": "string",
      "defaultValue": "2d9ce5fe-1b0c-44e5-ba36-c93225179d83",
      "metadata": { "description": "Secret object ID (not used by PRTG directly — kept for reference)." }
    }

  },

  "variables": {

    "cloudlabsCommon": "[concat(' -AzureUserName ', parameters('AzureUserName'), ' -AzurePassword ', parameters('AzurePassword'), ' -AzureTenantID ', variables('AzureTenantID'), ' -AzureSubscriptionID ', variables('AzureSubscriptionID'), ' -ODLID ', parameters('ODLID'), ' -InstallCloudLabsShadow ', parameters('InstallCloudLabsShadow'))]",
    "Enable-CloudLabsEmbeddedShadow": "[concat(' -vmAdminUsername ', parameters('adminUsername'), ' -trainerUserName ', parameters('trainerUserName'), ' -trainerUserPassword ', parameters('trainerUserPassword'), ' -resetUserPassword ', parameters('resetUserPassword'))]",
    "AzureSubscriptionID": "[subscription().subscriptionId]",
    "AzureTenantID": "[subscription().tenantId]",
    "location": "[resourceGroup().location]",

    "vnetName": "prtg-shared-vnet",
    "vnetAddressPrefix": "10.10.0.0/16",
    "subnetName": "prtg-shared-subnet",
    "subnetPrefix": "10.10.0.0/24",
    "subnetRef": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]",

    "winVmName": "[concat('prtg-win-', parameters('DeploymentID'))]",
    "winNicName": "[concat('prtg-win-', parameters('DeploymentID'), '-nic')]",
    "winNsgName": "[concat('prtg-win-', parameters('DeploymentID'), '-nsg')]",
    "winPipName": "[concat('prtg-win-', parameters('DeploymentID'), '-pip')]",
    "winPipDns": "[toLower(concat('prtgwin', uniqueString(resourceGroup().id)))]",
    "winOsDisk": "[concat('prtg-win-osdisk-', parameters('DeploymentID'))]",
    "winVmSize": "Standard_B2s",
    "winComputerName": "prtgwinvm",

    "linuxVmName": "[concat('prtg-docker-', parameters('DeploymentID'))]",
    "linuxNicName": "[concat('prtg-docker-', parameters('DeploymentID'), '-nic')]",
    "linuxNsgName": "[concat('prtg-docker-', parameters('DeploymentID'), '-nsg')]",
    "linuxPipName": "[concat('prtg-docker-', parameters('DeploymentID'), '-pip')]",
    "linuxPipDns": "[toLower(concat('prtgdocker', uniqueString(resourceGroup().id)))]",
    "linuxOsDisk": "[concat('prtg-docker-osdisk-', parameters('DeploymentID'))]",
    "linuxVmSize": "Standard_B2s",
    "linuxComputerName": "prtgdockervm",

    "sqlServerName": "[toLower(concat('prtgsql', parameters('DeploymentID'), uniqueString(resourceGroup().id)))]",
    "sqlDbName": "prtgshareddb",

    "storageAccountName": "[toLower(concat('prtgsa', uniqueString(resourceGroup().id)))]",

    "spnClientId": "[parameters('spnClientId')]",
    "spnClientSecret": "[parameters('spnClientSecret')]",
    "spnSecretId": "[parameters('spnSecretId')]"

  },

  "resources": [

    {
      "comments": "VNet — self-contained networking for the shared PRTG lab RG. No dependency on external VNets.",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2022-11-01",
      "name": "[variables('vnetName')]",
      "location": "[variables('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [ "[variables('vnetAddressPrefix')]" ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "[variables('subnetPrefix')]"
            }
          }
        ]
      }
    },

    {
      "comments": "Windows Server 2022 VM — PRTG shared monitoring target. RDP (3389) inbound only.",
      "type": "Microsoft.Network/publicIpAddresses",
      "apiVersion": "2020-08-01",
      "name": "[variables('winPipName')]",
      "location": "[variables('location')]",
      "sku": { "name": "Standard", "tier": "Regional" },
      "properties": {
        "publicIpAllocationMethod": "Static",
        "dnsSettings": { "domainNameLabel": "[variables('winPipDns')]" }
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2020-05-01",
      "name": "[variables('winNsgName')]",
      "location": "[variables('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "allow-rdp",
            "properties": {
              "priority": 110,
              "protocol": "TCP",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "3389"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2022-11-01",
      "name": "[variables('winNicName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIpAddresses', variables('winPipName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('winNsgName'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": { "id": "[variables('subnetRef')]" },
              "privateIPAllocationMethod": "Dynamic",
              "publicIpAddress": {
                "id": "[resourceId('Microsoft.Network/publicIpAddresses', variables('winPipName'))]"
              }
            }
          }
        ],
        "networkSecurityGroup": {
          "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('winNsgName'))]"
        }
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[variables('winVmName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('winNicName'))]"
      ],
      "properties": {
        "hardwareProfile": { "vmSize": "[variables('winVmSize')]" },
        "storageProfile": {
          "osDisk": {
            "createOption": "FromImage",
            "name": "[variables('winOsDisk')]",
            "caching": "ReadWrite",
            "managedDisk": { "storageAccountType": "StandardSSD_LRS" },
            "diskSizeGB": 128
          },
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-Datacenter",
            "version": "latest"
          }
        },
        "osProfile": {
          "computerName": "[variables('winComputerName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminUserPassword')]",
          "windowsConfiguration": {
            "enableAutomaticUpdates": false,
            "provisionVMAgent": true
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('winNicName'))]" }
          ]
        }
      }
    },
    {
      "comments": "CloudLabs shadow agent + post-deploy setup on the Windows VM.",
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2015-06-15",
      "name": "[concat(variables('winVmName'), '/winExtension')]",
      "location": "[variables('location')]",
      "tags": { "displayName": "VM Extension" },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('winVmName'))]"
      ],
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.8",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "https://experienceazure.blob.core.windows.net/templates/paessler/win2025/generalized-vm/psscript.ps1",
            "https://experienceazure.blob.core.windows.net/templates/cloudlabs-common/cloudlabs-windows-functions.ps1"
          ]
        },
        "protectedSettings": {
          "commandToExecute": "[concat('powershell.exe -ExecutionPolicy Unrestricted -File paessler/win2025/generalized-vm/psscript.ps1', variables('cloudlabsCommon'), variables('Enable-CloudLabsEmbeddedShadow'))]"
        }
      }
    },

    {
      "comments": "Ubuntu 24.04 LTS VM — Docker CE installed via CustomScript. SSH (22) inbound only.",
      "type": "Microsoft.Network/publicIpAddresses",
      "apiVersion": "2020-08-01",
      "name": "[variables('linuxPipName')]",
      "location": "[variables('location')]",
      "sku": { "name": "Standard", "tier": "Regional" },
      "properties": {
        "publicIpAllocationMethod": "Static",
        "dnsSettings": { "domainNameLabel": "[variables('linuxPipDns')]" }
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2020-05-01",
      "name": "[variables('linuxNsgName')]",
      "location": "[variables('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "allow-ssh",
            "properties": {
              "priority": 110,
              "protocol": "TCP",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2022-11-01",
      "name": "[variables('linuxNicName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIpAddresses', variables('linuxPipName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('linuxNsgName'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": { "id": "[variables('subnetRef')]" },
              "privateIPAllocationMethod": "Dynamic",
              "publicIpAddress": {
                "id": "[resourceId('Microsoft.Network/publicIpAddresses', variables('linuxPipName'))]"
              }
            }
          }
        ],
        "networkSecurityGroup": {
          "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('linuxNsgName'))]"
        }
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[variables('linuxVmName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('linuxNicName'))]"
      ],
      "properties": {
        "hardwareProfile": { "vmSize": "[variables('linuxVmSize')]" },
        "storageProfile": {
          "osDisk": {
            "createOption": "FromImage",
            "name": "[variables('linuxOsDisk')]",
            "caching": "ReadWrite",
            "managedDisk": { "storageAccountType": "StandardSSD_LRS" },
            "diskSizeGB": 64
          },
          "imageReference": {
            "publisher": "Canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
          }
        },
        "osProfile": {
          "computerName": "[variables('linuxComputerName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminUserPassword')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": false
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('linuxNicName'))]" }
          ]
        }
      }
    },
    {
      "comments": "Install Docker CE from the official Docker apt repo. Pulls nginx and starts a demo container on port 8080 as a live PRTG monitoring target.",
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2021-11-01",
      "name": "[concat(variables('linuxVmName'), '/installDocker')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('linuxVmName'))]"
      ],
      "properties": {
        "publisher": "Microsoft.Azure.Extensions",
        "type": "CustomScript",
        "typeHandlerVersion": "2.1",
        "autoUpgradeMinorVersion": true,
        "protectedSettings": {
          "script": "[base64(concat('#!/bin/bash\nset -e\nexport DEBIAN_FRONTEND=noninteractive\napt-get update -y\napt-get install -y ca-certificates curl gnupg lsb-release\ninstall -m 0755 -d /etc/apt/keyrings\ncurl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg\nchmod a+r /etc/apt/keyrings/docker.gpg\n. /etc/os-release\necho \"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu ${VERSION_CODENAME} stable\" | tee /etc/apt/sources.list.d/docker.list > /dev/null\napt-get update -y\napt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin\nsystemctl enable docker\nsystemctl start docker\nusermod -aG docker ', parameters('adminUsername'), '\ndocker pull nginx:latest\ndocker run -d --name nginx-demo --restart always -p 8080:80 nginx:latest\necho \"Docker installation complete\" >> /var/log/docker-install.log\n'))]"
        }
      }
    },

    {
      "comments": "Azure SQL logical server — PRTG Azure SQL Database sensor target.",
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2022-05-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[variables('location')]",
      "properties": {
        "administratorLogin": "[parameters('adminUsername')]",
        "administratorLoginPassword": "[parameters('adminUserPassword')]",
        "version": "12.0",
        "publicNetworkAccess": "Enabled",
        "minimalTlsVersion": "1.2"
      }
    },
    {
      "comments": "Firewall rule — 0.0.0.0 to 0.0.0.0 is the Azure-services magic range. Allows PRTG (running inside Azure) to reach the SQL API without opening to the internet.",
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2022-05-01-preview",
      "name": "[concat(variables('sqlServerName'), '/AllowAllAzureServices')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      }
    },
    {
      "comments": "Basic-tier database — 5 DTU, 2 GB max, local backup redundancy. Sufficient for PRTG SQL sensor exercises.",
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2022-05-01-preview",
      "name": "[concat(variables('sqlServerName'), '/', variables('sqlDbName'))]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "sku": {
        "name": "Basic",
        "tier": "Basic",
        "capacity": 5
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS",
        "maxSizeBytes": 2147483648,
        "requestedBackupStorageRedundancy": "Local"
      }
    },

    {
      "comments": "StorageV2 Standard LRS — PRTG Azure Storage Account sensor target.",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageAccountName')]",
      "location": "[variables('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "networkAcls": {
          "bypass": "AzureServices",
          "defaultAction": "Allow"
        }
      }
    }

  ],

  "outputs": {

    "DeploymentID": {
      "type": "string",
      "value": "[parameters('DeploymentID')]"
    },

    "Windows VM - Name": {
      "type": "string",
      "value": "[variables('winVmName')]"
    },
    "Windows VM - DNS Name": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('winPipName'))).dnsSettings.fqdn]"
    },
    "Windows VM - Private IP": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/networkInterfaces', variables('winNicName'))).ipConfigurations[0].properties.privateIPAddress]"
    },

    "Docker VM - Name": {
      "type": "string",
      "value": "[variables('linuxVmName')]"
    },
    "Docker VM - DNS Name": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('linuxPipName'))).dnsSettings.fqdn]"
    },
    "Docker VM - Private IP": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/networkInterfaces', variables('linuxNicName'))).ipConfigurations[0].properties.privateIPAddress]"
    },

    "SQL Server - Name": {
      "type": "string",
      "value": "[variables('sqlServerName')]"
    },
    "SQL Server - FQDN": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName'))).fullyQualifiedDomainName]"
    },
    "SQL Database - Name": {
      "type": "string",
      "value": "[variables('sqlDbName')]"
    },
    "SQL Admin Username": {
      "type": "string",
      "value": "[parameters('adminUsername')]"
    },

    "Storage Account - Name": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },

    "VM Admin Username": {
      "type": "string",
      "value": "[parameters('adminUsername')]"
    },
    "VM Admin Password": {
      "type": "string",
      "value": "[parameters('resetUserPassword')]"
    },

    "PRTG Azure - Tenant ID": {
      "type": "string",
      "value": "[variables('AzureTenantID')]"
    },
    "PRTG Azure - Subscription ID": {
      "type": "string",
      "value": "[variables('AzureSubscriptionID')]"
    },
    "PRTG Azure - SPN Name": {
      "type": "string",
      "value": "[variables('spnClientId')]"
    },
    "PRTG Azure - Client Secret": {
      "type": "string",
      "value": "[variables('spnClientSecret')]"
    },
    "PRTG Azure - Secret Object ID": {
      "type": "string",
      "value": "[variables('spnSecretId')]"
    }

  }
}
